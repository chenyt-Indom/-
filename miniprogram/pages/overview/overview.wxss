/* 总览地图页样式 */
.container { width: 100%; height: 100vh; display: flex; flex-direction: column; }
.map-wrapper { flex: 1; position: relative; }
.overview-map { width: 100%; height: 100%; }
.map-legend { position: absolute; top: 20rpx; left: 50%; transform: translateX(-50%); background: rgba(0,0,0,0.6); padding: 10rpx 24rpx; border-radius: 24rpx; }
.legend-text { color: #fff; font-size: 22rpx; }
.bottom-bar { padding: 20rpx 30rpx 40rpx; background: #fff; }
.spot-summary { text-align: center; margin-bottom: 16rpx; }
.summary-text { font-size: 26rpx; color: #666; }
.btn-detail { width: 100%; height: 88rpx; line-height: 88rpx; background: linear-gradient(135deg, #4A90D9, #357ABD); color: #fff; border-radius: 44rpx; font-size: 30rpx; font-weight: 600; margin-bottom: 16rpx; border: none; }
.btn-back { width: 100%; height: 88rpx; line-height: 88rpx; background: #fff; color: #4A90D9; border: 1rpx solid #4A90D9; border-radius: 44rpx; font-size: 28rpx; }