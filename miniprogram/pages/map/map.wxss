/* 地图页样式 */
.map-container { width: 100%; height: 100vh; position: relative; }
.trip-map { width: 100%; height: 100%; }
.map-legend { position: absolute; bottom: 40rpx; left: 50%; transform: translateX(-50%); background: rgba(0,0,0,0.6); padding: 12rpx 24rpx; border-radius: 24rpx; }
.legend-text { color: #fff; font-size: 24rpx; }