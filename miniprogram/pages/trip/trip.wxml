<!-- 行程展示页：卡片详情 + 预约提醒 + 机票/酒店/门票推荐 -->
<view class="container">
  <!-- 天气概览 -->
  <view class="weather-bar" wx:if="{{tripData.weather && tripData.weather.length}}">
    <scroll-view scroll-x class="weather-scroll">
      <view class="weather-item" wx:for="{{tripData.weather}}" wx:key="date">
        <text class="w-icon">{{item.icon}}</text>
        <text class="w-date">{{item.date}}</text>
        <text class="w-desc">{{item.weather}}</text>
        <text class="w-temp">{{item.temp}}</text>
      </view>
    </scroll-view>
  </view>

  <!-- 按天行程卡片 -->
  <view class="day-card" wx:for="{{tripData.itinerary}}" wx:key="day" wx:for-index="dayIdx">
    <view class="card-header">
      <view class="day-badge">Day {{item.day}}</view>
      <view class="day-date">{{item.date}}</view>
      <view class="day-weather" wx:if="{{item.weather}}">
        <text>{{item.weather.icon}} {{item.weather.desc}} {{item.weather.temp}}</text>
      </view>
      <view class="map-icon-btn" bindtap="onOpenAmap" data-day="{{dayIdx}}">
        <text class="map-icon">🗺️</text>
        <text class="map-text">高德地图</text>
      </view>
    </view>

    <image class="weather-img" wx:if="{{item.weather && item.weather.image}}" 
      src="{{item.weather.image}}" mode="aspectFill" />

    <!-- 上午/下午/晚上 -->
    <block wx:for="{{slots}}" wx:for-item="slot" wx:key="name">
      <view class="time-slot" wx:if="{{item[slot.key]}}">
        <view class="slot-header">
          <view class="slot-dot {{slot.key}}"></view>
          <text class="slot-title">{{slot.label}}</text>
          <text class="map-icon-small" wx:if="{{item[slot.key].location}}" 
            bindtap="onOpenAmap" data-day="{{dayIdx}}">📍</text>
        </view>
        <image class="spot-img" wx:if="{{item[slot.key].image}}" 
          src="{{item[slot.key].image}}" mode="aspectFill" />
        <view class="spot-name">{{item[slot.key].spot}}</view>
        <view class="spot-meta">
          <text class="meta-tag">时长：{{item[slot.key].duration}}</text>
          <text class="meta-tag booking" wx:if="{{item[slot.key].need_booking}}">⚠需预约</text>
        </view>
        <view class="spot-coord" wx:if="{{item[slot.key].location}}">
          <text class="coord-icon">📌</text>
          <text class="coord-text">坐标：{{item[slot.key].location}}</text>
        </view>
        <view class="spot-reason">推荐理由：{{item[slot.key].reason}}</view>
      </view>
    </block>

    <view class="day-footer">
      <view class="footer-row">
        <text class="footer-icon">🍜</text><text class="footer-label">午餐：</text><text class="footer-text">{{item.lunch}}</text>
      </view>
      <view class="footer-row">
        <text class="footer-icon">🍽️</text><text class="footer-label">晚餐：</text><text class="footer-text">{{item.dinner}}</text>
      </view>
      <view class="footer-row">
        <text class="footer-icon">🚗</text><text class="footer-label">交通：</text><text class="footer-text">{{item.transport}}</text>
      </view>
    </view>
  </view>

  <!-- 预算明细 -->
  <view class="bottom-card" wx:if="{{tripData.budget_breakdown}}">
    <view class="bottom-title">预算明细</view>
    <view class="budget-grid">
      <view class="budget-item" wx:for="{{budgetList}}" wx:key="name">
        <text class="budget-name">{{item.name}}</text>
        <text class="budget-value">{{item.value}}</text>
      </view>
    </view>
  </view>

  <!-- 机票/火车票推荐 -->
  <view class="bottom-card" wx:if="{{booking.flights.length}}">
    <view class="bottom-title">✈️ 机票/火车票</view>
    <view class="booking-item" wx:for="{{booking.flights}}" wx:key="type">
      <view class="booking-row">
        <text class="booking-type">{{item.type}}</text>
        <text class="booking-suggest">{{item.suggest}}</text>
      </view>
      <view class="booking-row sub">
        <text class="booking-price">{{item.price}}</text>
        <text class="booking-note">{{item.note}}</text>
      </view>
      <button class="btn-book" bindtap="onBookLink" data-link="{{item.link}}" data-name="{{item.suggest}}">立即订购</button>
    </view>
  </view>

  <!-- 酒店推荐 -->
  <view class="bottom-card" wx:if="{{booking.hotels.length}}">
    <view class="bottom-title">🏨 酒店推荐</view>
    <view class="booking-item" wx:for="{{booking.hotels}}" wx:key="name">
      <view class="booking-row">
        <text class="booking-hotel-name">{{item.name}}</text>
      </view>
      <view class="booking-row sub">
        <text class="booking-area">{{item.area}}</text>
        <text class="booking-price">{{item.price}}</text>
      </view>
      <view class="booking-reason">{{item.reason}}</view>
      <view class="booking-row sub" wx:if="{{item.location}}">
        <text class="coord-text">📌 {{item.location}}</text>
      </view>
      <button class="btn-book" bindtap="onBookLink" data-link="{{item.link}}" data-name="{{item.name}}">预订酒店</button>
    </view>
  </view>

  <!-- 门票预约提醒 -->
  <view class="bottom-card" wx:if="{{booking.tickets.length}}">
    <view class="bottom-title">🎫 门票预约（需提前预约）</view>
    <view class="booking-item ticket-item" wx:for="{{booking.tickets}}" wx:key="spot">
      <view class="booking-row">
        <text class="ticket-spot">{{item.spot}}</text>
        <text class="ticket-price">{{item.price}}</text>
      </view>
      <view class="booking-row sub" wx:if="{{item.need_booking}}">
        <text class="ticket-booking-warn">⚠ 需提前{{item.booking_days}}预约</text>
      </view>
      <view class="booking-row sub">
        <text class="ticket-platform">平台：{{item.platform}}</text>
      </view>
      <view class="ticket-note">{{item.note}}</view>
      <button class="btn-book warn" bindtap="onBookLink" data-link="{{item.link}}" data-name="{{item.spot}}">去预约</button>
    </view>
  </view>

  <!-- 预约贴士 -->
  <view class="bottom-card" wx:if="{{booking.booking_tips.length}}">
    <view class="bottom-title">📋 预约贴士</view>
    <view class="tips-list">
      <view class="tip-item" wx:for="{{booking.booking_tips}}" wx:key="index">
        <text class="tip-dot">•</text>
        <text class="tip-text">{{item}}</text>
      </view>
    </view>
  </view>

  <!-- 出行贴士 -->
  <view class="bottom-card" wx:if="{{tripData.tips && tripData.tips.length}}">
    <view class="bottom-title">出行贴士</view>
    <view class="tips-list">
      <view class="tip-item" wx:for="{{tripData.tips}}" wx:key="index">
        <text class="tip-dot">•</text>
        <text class="tip-text">{{item}}</text>
      </view>
    </view>
  </view>

  <button class="btn-share" bindtap="onShare">分享行程</button>
  <button class="btn-back" bindtap="onBack">返回总览地图</button>
  <canvas canvas-id="shareCanvas" style="position:fixed;top:-9999px;left:-9999px;width:375px;height:500px;"></canvas>
</view>