[Unit]
Description=旅白行 AI 旅行规划后端
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/lvbai/backend
EnvironmentFile=/opt/lvbai/deploy/.env
ExecStart=/usr/bin/python3 -m uvicorn main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target